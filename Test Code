from pypowerautomate.flow import Flow
from pypowerautomate.triggers import ManualTrigger
from pypowerautomate.actions import InitVariableAction, VariableTypes

# Initialize the flow
my_flow = Flow(name="My_Local_Flow")

# Add a trigger
my_flow.set_trigger(ManualTrigger())

# Add an action
my_flow.add_action(InitVariableAction(
    name="Greeting", 
    var_type=VariableTypes.string, 
    value="Hello from Python!"
))

# Export as a legacy package (ZIP)
my_flow.export_package("my_flow_package.zip")


