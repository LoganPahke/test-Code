import json
import os
from datetime import datetime

# 1. Capture the Input Variable from Power Automate Desktop
# Ensure you have created an Input Variable named DataverseRowJson in PAD
raw_input = "%DataverseRowJson%"

def process_test_job(json_data):
    try:
        # 2. Parse the JSON sent from the Cloud
        data = json.loads(json_data)
        
        job_id = data.get("job_id", "N/A")
        job_name = data.get("job_name", "Untitled Job")
        priority = data.get("priority", "Normal")
        
        # 3. YOUR DECISION LOGIC
        # This is where you decide the Cell Assignment
        if "heavy" in job_name.lower() or (isinstance(priority, int) and priority > 5):
            assignment = "Cell A"
        else:
            assignment = "Cell B"
            
        # 4. LOGGING (Optional - for your own records)
        log_entry = f"[{datetime.now()}] Job: {job_name} -> Assigned to: {assignment}\n"
        path = os.path.join(os.path.expanduser("~"), "Documents", "TestJobs_Log.txt")
        with open(path, "a") as f:
            f.write(log_entry)
            
        # 5. THE OUTPUT
        # This print statement is what Power Automate Desktop captures 
        # to send back to the Cloud Flow.
        print(assignment)
        
    except Exception as e:
        print(f"Python Error: {str(e)}")

# Execute the function
process_test_job(raw_input)
