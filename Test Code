import json
import os
from datetime import datetime

# 1. Capture the Input Variable from Power Automate
raw_input = "%DataverseRowJson%"

def process_test_job(json_data):
    try:
        # 2. Parse the JSON
        data = json.loads(json_data)
        
        job_id = data.get("job_id", "N/A")
        job_name = data.get("job_name", "Untitled Job")
        priority = data.get("priority", "Normal")
        
        # 3. YOUR PROGRAMMING LOGIC
        # Example: Triggering a local build or specialized test script
        log_entry = f"[{datetime.now()}] STARTING TEST: {job_name} (ID: {job_id}) | Priority: {priority}\n"
        
        # Writing to a local file as proof of work
        path = os.path.join(os.path.expanduser("~"), "Documents", "TestJobs_Log.txt")
        with open(path, "a") as f:
            f.write(log_entry)
            
        print(f"Successfully initiated Job: {job_name}")
        
    except Exception as e:
        print(f"Python Error: {str(e)}")

# Execute
process_test_job(raw_input) 
